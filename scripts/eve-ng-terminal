#!/bin/bash
# ==============================================================================
# EVE-NG Terminal Wrapper for Kitty
# ==============================================================================
# This script is called by eve-ng-integration to open sessions in Kitty tabs.
# It uses the Kitty remote control feature.

# Path to the Kitty socket (must match kitty.conf)
SOCKET="unix:/tmp/mykitty-shared"

if [ -z "$1" ]; then
    echo "Usage: $0 <command>"
    exit 1
fi

# Check if kitty is running
if pgrep -f "kitty --single-instance --instance-group master" > /dev/null; then
    # Open in a new tab in the master instance
    /usr/bin/kitty --single-instance --instance-group master @ launch --type=tab --tab-title "EVE-NG: $1" sh -c "$*"
else
    # Fallback: Just open using the master instance group
    /usr/bin/kitty --single-instance --instance-group master --title "EVE-NG: $1" sh -c "$*"
fi
